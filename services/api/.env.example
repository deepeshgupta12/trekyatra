APP_NAME=TrekYatra API
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1

POSTGRES_SERVER=localhost
POSTGRES_PORT=5433
POSTGRES_DB=trekyatra
POSTGRES_USER=trekyatra
POSTGRES_PASSWORD=trekyatra

REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_DB=0

# Celery — broker and result backend use Redis DB 1 (separate from cache on DB 0)
# Derived automatically from REDIS_HOST/REDIS_PORT; override here if needed
# CELERY_BROKER_URL=redis://localhost:6380/1
# CELERY_RESULT_BACKEND=redis://localhost:6380/1

WORDPRESS_BASE_URL=http://localhost:8080
WORDPRESS_USERNAME=admin
WORDPRESS_APP_PASSWORD=replace_me
WORDPRESS_TIMEOUT_SECONDS=10
WORDPRESS_VERIFY_SSL=false

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SMS_PROVIDER=
SMS_API_KEY=

AUTH_JWT_SECRET=trekyatra-dev-secret-key-at-least-32-bytes-long
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_COOKIE_NAME=trekyatra_access_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax